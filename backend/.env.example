# Copy to .env and fill in the keys you have. Anything left blank falls back to a mock.

# --- LLM (Gemini via Google AI Studio: https://aistudio.google.com/apikey) ---
GOOGLE_API_KEY=
# Override model names only if you need to:
# MODEL_REASONING=gemini-3.5-flash
# MODEL_NARRATIVE=gemini-3.1-pro

# --- Optional signal enrichers ---
TAVILY_API_KEY=
FRED_API_KEY=

# --- Frontend origin for CORS ---
FRONTEND_ORIGIN=http://localhost:3000
